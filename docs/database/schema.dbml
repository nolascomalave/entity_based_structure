// ===============================================
// Departamento (jerárquico, por entidad jurídica)
// ===============================================
Table department {
  id uuidv7 [pk, unique, not null]
  entity_id uuidv7 [ref: > entity.id, note: "Must be null if parent_id fiel is not null. If parent_id field is null, this field must be not null."] // entidad jurídica dueña del departamento
  parent_id uuidv7 [ref: > department.id, note: "Must be null if entity_id fiel is not null. If entity_id field is null, this field must be not null."] // jerarquía (null = raíz)
  name varchar(250) [not null]
  description text
  code varchar(50) // opcional: código de departamento
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]

  Indexes {
    (entity_id) [name: "idx_department_entity"]
    (parent_id) [name: "idx_department_parent"]
    (entity_id, name) [unique, name: "idx_department_entity_name"]
  }
}

// ==============================================
// Familia de Cargos (Job Family)
// ==============================================
Table job_family {
  id uuidv7 [pk, unique, not null]
  entity_id uuidv7 [not null, ref: > entity.id]
  name varchar(250) [not null]
  description text
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]

  Indexes {
    (entity_id, name) [unique, name: "idx_job_family_unique"]
    (entity_id) [name: "idx_job_family_entity"]
  }
}

// ====================================================
// Cargo (Position) – jerárquico (reporta a otro cargo)
// ====================================================
Table position {
  id uuidv7 [pk, unique, not null]
  entity_id uuidv7 [ref: > entity.id, note: "Must be null if parent_id fiel is not null. If parent_id field is null, this field must be not null."] // entidad jurídica dueña del departamento
  parent_id uuidv7 [ref: > department.id, note: "Must be null if entity_id fiel is not null. If entity_id field is null, this field must be not null."] // jerarquía (null = raíz)
  job_family_id uuidv7 [ref: > job_family.id] // opcional, puede no tener familia
  department_id uuidv7 [ref: > department.id] // departamento al que pertenece
  name varchar(250) [not null]
  description text

  // Nivel jerárquico (opcional, para facilitar consultas)
  // level int

  // Auditoría
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]

  Indexes {
    (entity_id, name) [name: "idx_position_unique"]
    (entity_id) [name: "idx_position_entity"]
    (job_family_id) [name: "idx_position_job_family"]
    (department_id) [name: "idx_position_department"]
    (parent_id) [name: "idx_position_parent"]
  }
}

// ==========================================================================
// Empleado (relaciona persona natural como empleado de una entidad jurídica)
// ==========================================================================
Table employee {
  id uuidv7 [pk, unique, not null]
  person_entity_id uuidv7 [not null, ref: > entity.id] // la persona (is_natural = true)
  legal_entity_id uuidv7 [not null, ref: > entity.id] // empresa donde trabaja (is_natural = false)
  employee_code varchar(100) [not null] // código interno
  is_active boolean [not null, default: true]
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]

  Indexes {
    (person_entity_id, legal_entity_id) [unique, name: "employee_idx_unique"]
    (legal_entity_id, employee_code) [unique, name: "idx_employee_code_per_entity"]
    (person_entity_id) [name: "idx_employee_person"]
    (legal_entity_id) [name: "idx_employee_legal_entity"]
  }
}

// =====================================================================================================
// Vigencia del empleado (establece las fechas de inicio y fin de periodos de un empleado en la empresa)
// =====================================================================================================
Table employee_validity {
  id int [pk, not null, increment]
  employee_id uuidv7 [not null, ref: > employee.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  annulled_at timestampz
  annulled_by uuidv7

  Indexes {
    (employee_id, start_date) [name: "employee_validity_idx_unique"]
    (employee_id) [name: "employee_validity_idx_employee"]
    (created_by) [name: "employee_validity_idx_created_by"]
    (updated_by) [name: "employee_validity_idx_updated_by"]
    (annulled_by) [name: "employee_validity_idx_annulled_by"]
  }
}

// ============================================================================
// Empleado por Cargo (relaciona empleado con un cargo de una entidad jurídica)
// ============================================================================
Table employee_per_position {
  id uuidv7 [pk, unique, not null]
  employee_id uuidv7 [not null, ref: > employee.id]
  position_id uuidv7 [not null, ref: > position.id, note: "Must not exists 2 or more records with same position_id and is_active value in \"true\""]
  is_active boolean [not null, default: true]
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]

  Indexes {
    (employee_id, position_id) [unique, name: "employee_per_position_idx_unique"]
    (employee_id) [name: "employee_per_position_idx_employee"]
    (position_id) [name: "employee_per_position_idx_position"]
  }
}

// ============================================================================
// Vigencia de Empleado por Cargo (Historial de vigencia de empleado por cargo)
// ============================================================================
Table employee_per_position_validity {
  id int [pk, not null, increment]
  employee_per_position_id uuidv7 [not null, ref: > employee_per_position.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  annulled_at timestampz
  annulled_by uuidv7

  Indexes {
    (employee_per_position_id, start_date) [name: "employee_per_position_idx_unique"]
    (employee_per_position_id) [name: "employee_per_position_idx_employee"]
    (created_by) [name: "employee_per_position_idx_created_by"]
    (updated_by) [name: "employee_per_position_idx_updated_by"]
    (annulled_by) [name: "employee_per_position_idx_annulled_by"]
  }
}

// ================================================================================================================
// Participación accionaria (participación accionaria de una entidad natural o jurídica sobre una entidad jurídica)
// ================================================================================================================
Table shareholding {
  id uuidv7 [pk, unique, not null]
  entity_id uuidv7 [not null, ref: > entity.id] // entidad jurídica que tiene accionistas.
  shareholer_entity_id uuidv7 [not null, ref: > entity.id] // accionista (puede ser natural o jurídica)
  is_active boolean [not null, default: true]
  ownership_percentage decimal(5,2) // porcentaje de participación
  shares_quantity bigint // cantidad de acciones (opcional)
  // share_class varchar(50) // clase de acción (ej: A, B, preferente)

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  annulled_at timestampz
  annulled_by uuidv7

  Indexes {
    (entity_id) [name: "shareholding_idx_entity"]
    (shareholer_entity_id) [name: "shareholding_idx_shareholer"]
    (created_by) [name: "shareholding_idx_created_by"]
    (updated_by) [name: "shareholding_idx_updated_by"]
    (annulled_by) [name: "shareholding_idx_annulled_by"]
  }
}

// ==========================================================================================================================
// Vigencia de la Participación accionaria (establece las fechas de inicio y fin de periodos de una participación accionaria)
// ==========================================================================================================================
Table shareholding_validity {
  id uuidv7 [pk, unique, not null]
  shareholding_id uuidv7 [not null, ref: > shareholding.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  annulled_at timestampz
  annulled_by uuidv7

  Indexes {
    (shareholding_id) [name: "shareholding_validity_idx_employee"]
    (created_by) [name: "shareholding_validity_idx_created_by"]
    (updated_by) [name: "shareholding_validity_idx_updated_by"]
    (annulled_by) [name: "shareholding_validity_idx_annulled_by"]
  }
}

// ==============================================
// Subsidiaria (relación matriz -> filial)
// ==============================================
Table subsidiary {
  id uuidv7 [pk, unique, not null]
  entity_id uuidv7 [not null, ref: > entity.id] // entidad filial (is_natural = false)
  parent_entity_id uuidv7 [not null, ref: > entity.id] // entidad matriz (is_natural = false)
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]

  Indexes {
    (parent_entity_id) [name: "idx_subsidiary_parent"]
    (entity_id) [name: "idx_subsidiary_child"]
    (parent_entity_id, entity_id) [unique, name: "idx_subsidiary_unique_pair"]
  }
}

// ==========================================================================================================================
// Vigencia de la Participación accionaria (establece las fechas de inicio y fin de periodos de una participación accionaria)
// ==========================================================================================================================
Table subsidiary_validity {
  id uuidv7 [pk, unique, not null]
  subsidiary_id uuidv7 [not null, ref: > subsidiary.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  annulled_at timestampz
  annulled_by uuidv7

  Indexes {
    (subsidiary_id) [name: "subsidiary_validity_idx_subsidiary"]
    (created_by) [name: "subsidiary_validity_idx_created_by"]
    (updated_by) [name: "subsidiary_validity_idx_updated_by"]
    (annulled_by) [name: "subsidiary_validity_idx_annulled_by"]
  }
}

// ==============================================
// Rama (relación matriz -> rama - sucursal)
// ==============================================
Table branch {
  id uuidv7 [pk, unique, not null]
  entity_id uuidv7 [ref: > entity.id, note: "This field can be null when parent_id field is not null, else this field must be not null."]  // entidad jurídica dueña de la sucursal
  parent_id uuidv7 [ref: > branch.id, note: "This field can be null when entity_id field is not null, else this field must be not null."]  // rama padre de la sucursal
  position_id uuidv7 [ref: > position.id]  // cargo encargado de la sucursal
  is_headquarters boolean [default: false] // si es la casa matriz
  code varchar(50)                      // código interno
  name varchar(250) [null]          // "Sucursal Norte", "Oficina Madrid"
  /* address text
  city varchar(100)
  country varchar(100)
  phone varchar(50) */

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  annulled_at timestampz
  annulled_by uuidv7

  Indexes {
    (entity_id, parent_id, code) [name: "subsidiary_validity_idx_unique"]
    (entity_id) [name: "subsidiary_validity_idx_entity"]
    (parent_id) [name: "subsidiary_validity_idx_parent"]
    (created_by) [name: "subsidiary_validity_idx_created_by"]
    (updated_by) [name: "subsidiary_validity_idx_updated_by"]
    (annulled_by) [name: "subsidiary_validity_idx_annulled_by"]
  }
}

Table identity_document_by_entity_by_branch {
  id uuidv7 [pk, unique, not null]
  branch_id uuidv7 [not null, ref: > branch.id]
  identity_document_by_entity_id uuidv7 [not null, ref: > identity_document_by_entity.id]
