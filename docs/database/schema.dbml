    (updated_by) [name: "entity_name_type_idx_updated_by"]
    (inactivated_by) [name: "entity_name_type_idx_inactivated_by"]
    (annulled_by) [name: "entity_name_type_idx_annulled_by"]
  }
}

Table entity_name_by_entity {
  entity_id uuidv7 [not null, ref: > entity.id]
  entity_name_id uuidv7 [not null, ref: > entity_name.id]
  entity_name_type_id uuidv7 [not null, ref: > entity_name_type.id]
  ordering_by_type int [not null, default: 0]
  ordering int [not null, default: 0]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  created_by uuidv7 [not null]
  updated_at timestampz [not null, default: "now()"]
  updated_by uuidv7 [not null]
  inactivated_at timestampz
  inactivated_by uuidv7
  annulled_at timestampz
