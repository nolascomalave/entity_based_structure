Table tenants.attached_documents {
  uuid uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  origin_table varchar(250) [not null]
  origin_id uuidv7 [not null]
  original_name varchar(250) [not null]
  document_name varchar(250) [unique, not null]
  extension varchar(20) [not null]
  mime_type varchar(100) [not null]
  bytes_size uuidv7 [not null]
  storage_route varchar(2500) [not null]
  disk varchar(50) [default: "local"]
  document_hash varchar(64)
  description text
  // tags text[] []

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    origin_id [name: "attached_documents_idx_origin"]
    system_subscription_id [name: "attached_documents_idx_system_subscription"]
  }
}