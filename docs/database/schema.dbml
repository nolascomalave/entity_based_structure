    (updated_by) [name: "email_idx_updated_by"]
    (inactivated_by) [name: "email_idx_inactivated_by"]
    (annulled_by) [name: "email_idx_annulled_by"]
  }
}

Table email_by_entity {
  email_id uuidv7 [not null, ref: > email.id]
  entity_id uuidv7 [not null, ref: > entity.id]
  preferred boolean [not null, default: false]
  ordering int [not null, default: 0]

  // Campos de registro de acción:
