Project organizational_structure_based_system {
  database_type: 'PostgreSQL'
  Note: '''This will be a system multitenancy for manage organizational structure for each tenants.

  Each employee of each tenant will have access to the system by its position inside of its organizational
  structure tenants.'''
}

Enum osbs.gender {
  Male
  Female
}

// ------------------------------------------------------------------
// Tablas maestras (Esquema maestro): -------------------------------
// ------------------------------------------------------------------
Table osbs.audit_log {
  id uuidv7 [pk, unique, not null]
  record_id uuidv7 [not null]         // o el tipo de PK de la tabla afectada
  table_name varchar(100) [not null]
  action varchar(10) [not null]       // 'INSERT', 'UPDATE', 'DELETE'
  old_data jsonb
  new_data jsonb
  changed_at timestampz [not null, default: "now()"]
  // session_id uuidv7                   // opcional, según cómo obtengas la sesión global
  // No lleva system_subscription_id porque no aplica a datos globales
  Indexes {
    (table_name, record_id) [name: "audit_log_idx_table_record"]
    record_id [name: "audit_log_idx_record"]
  }
}

Table osbs.regions {
  id uuidv7 [pk, unique, not null]
}

Table osbs.subregions {
  id uuidv7 [pk, unique, not null]
  region_id uuidv7 [not null, ref: > osbs.regions.id]

  Indexes {
    region_id [name: "subregions_idx_region"]
  }
}

Table osbs.countries {
  id uuidv7 [pk, unique, not null]
  region_id uuidv7 [not null, ref: > osbs.regions.id]
  subregion_id uuidv7 [ref: > osbs.subregions.id]

  Indexes {
    region_id [name: "countries_idx_region"]
    subregion_id [name: "countries_idx_subregion"]
  }
}

Table osbs.states {
  id uuidv7 [pk, unique, not null]
  country_id uuidv7 [not null, ref: > osbs.countries.id]

  Indexes {
    country_id [name: "states_idx_country"]
  }
}

Table osbs.cities {
  id uuidv7 [pk, unique, not null]
  state_id uuidv7 [not null, ref: > osbs.states.id]

  Indexes {
    state_id [name: "cities_idx_state"]
  }
}

Table osbs.system_subscription {
  id uuidv7 [pk, unique, not null]
  // entity_id uuidv7 [unique, not null/* , ref: > tenant.entity_id */]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz
}

Table osbs.system_subscription_validity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    system_subscription_id [name: "system_subscription_validity_idx_system_subscription"]
  }
}

Table osbs.system_client {
  id uuidv7 [pk, unique, not null]
  name varchar(250) [unique, not null]
  description text
  is_active boolean [not null, default: true]
}

Table osbs.phone {
  id uuidv7 [pk, unique, not null]
  country_id uuidv7 [not null, ref: > osbs.countries.id]
  state_id uuidv7 [ref: > osbs.states.id]
  phone varchar(50) [unique, not null]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (country_id, state_id, phone) [name: "phone_idx_unique"]
    // (country_id) [name: "phone_idx_country"]
    (state_id) [name: "phone_idx_state"]
  }
}

Table osbs.email {
  id uuidv7 [pk, unique, not null]
  email email [unique, not null]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz
}
// ------------------------------------------------------------------
// ------------------------------------------------------------------

// ------------------------------------------------------------------
// Tablas de la lógica de negocio (Esquema de tenants): -------------
// ------------------------------------------------------------------
Table tenants.audit_log {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  record_id uuidv7 [not null]
  user_access_id uuidv7 [ref: > tenants.user_access.id]
  table_name varchar(100) [not null]
  action varchar(10) [not null]       // 'INSERT', 'UPDATE', 'DELETE', 'ANNUL'
  old_data jsonb
  new_data jsonb
  changed_at timestampz [not null, default: "now()"]
  session_id uuidv7 [ref: > tenants.session.id, note: "En migración: ON DELETE SET NULL"]

  Indexes {
    system_subscription_id [name: "audit_log_idx_system_subscription"]
    (table_name, record_id) [name: "audit_log_idx_table_record"]
    record_id [name: "audit_log_idx_record"]
    (system_subscription_id, changed_at) [name: "audit_log_idx_subscription_time"]  // útil para consultas por tenant y fecha
  }
}

Table tenants.system_subscription_owner {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [unique, not null, ref: > osbs.system_subscription.id] // FK a global
  entity_id uuidv7 [not null, ref: > tenants.entity.id]

  Indexes {
    entity_id [name: "system_subscription_owner_idx_entity"]
  }
}

Table tenants.system_subscription_client {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  system_client_id uuidv7 [ref: > osbs.system_client.id]
  // parent_id uuidv7 [ref: > tenants.system_subscription_client.id]
  name varchar(250) [not null]
  description text
  is_active boolean [not null, default: true]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (system_subscription_id/* , parent_id */, name) [unique]
    system_subscription_id [name: "system_subscription_client_idx_system_subscription"]
    // parent_id [name: "system_subscription_client_idx_parent"]
  }
}

Table tenants.user_access {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  system_subscription_client_id uuidv7 [not null, ref: > tenants.system_subscription_client.id]
  email_by_entity_id uuidv7 [not null/* , ref: > osbs.email_by_entity.id */]
  password text [not null]
  is_active boolean [not null, default: true]

  Indexes {
    (system_subscription_client_id, email_by_entity_id) [unique, name: "user_access_idx_unique"]
    system_subscription_id [name: "user_access_idx_system_subscription"]
  }
}

/* Table tenants.password_history {
  id uuidv7 [pk, unique, not null]
} */

Table tenants.user_access_validity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  user_access_id uuidv7 [not null, ref: > tenants.user_access.id]
  start_date timestampz [not null, default: "now()"]
  end_date timestampz

  Indexes {
    system_subscription_id [name: "user_access_validity_idx_system_subscription"]
  }
}

Table tenants.session {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  user_access_id uuidv7 [ref: > tenants.user_access.id]
  refreshToken text [not null]
  created_at timestampz [not null, default: "now()"]
  expires_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    system_subscription_id [name: "session_idx_system_subscription"]
    user_access_id [name: "session_idx_user_access"]
  }
}

Table tenants.recovery_password {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  user_access_id uuidv7 [ref: > tenants.user_access.id]
  validity_code varchar(10) [not null]
  created_at timestampz [not null, default: "now()"]
  expires_at timestampz [not null, default: "now()"]
  used_at timestampz
  deleted_at timestampz

  Indexes {
    system_subscription_id [name: "recovery_password_idx_system_subscription"]
    user_access_id [name: "recovery_password_idx_user_access"]
  }
}

Table tenants.recovery_password_notify {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  recovery_password_id uuidv7 [not null, ref: > tenants.recovery_password.id]
  phone_by_entity_id uuid /* [ref: > tenants.phone_by_entity.id] */
  email_by_entity_id uuid /* [ref: > tenants.email_by_entity.id] */
  created_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    system_subscription_id [name: "recovery_password_notify_idx_system_subscription"]
    recovery_password_id [name: "recovery_password_notify_idx_recovery_password"]
  }
}

// Vamos por aquí.
Table tenants.entity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  fusion_master_entity_id uuidv7 [ref: > tenants.entity.id]
  is_natural boolean [not null, default: false]
  identity_document varchar(250)
  name varchar(250) [null]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  fusioned_at timestampz
  fusioned_by uuidv7
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    system_subscription_id [name: "entity_idx_system_subscription"]
    fusion_master_entity_id [name: "entity_idx_fusion_master_entity"]
  }
}

Table tenants.natural_entity {
  entity_id uuidv7 [unique, not null, ref: - tenants.entity.id]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  gender gender [not null]
  birth_date date

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    entity_id [name: "natural_entity_idx_entity"]
    system_subscription_id [name: "natural_entity_idx_system_subscription"]
  }
}

Table tenants.identity_document_category {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  parent_id uuidv7 [not null, ref: > tenants.identity_document_category.id]
  region_id uuidv7 [ref: > osbs.regions.id]
  subregion_id uuidv7 [ref: > osbs.subregions.id]
  country_id uuidv7 [ref: > osbs.countries.id]
  state_id uuidv7 [ref: > osbs.states.id]
  city_id uuidv7 [ref: > osbs.cities.id]
  apply_to_natural boolean [not null, default: true]
  apply_to_legal boolean [not null, default: true]
  category varchar(250) [not null]
  symbol varchar(50)
  abbreviation varchar(50)

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (system_subscription_id, parent_id, region_id, subregion_id, country_id, state_id, city_id) [unique, name: "idx_identity_document_category_unique"]
    system_subscription_id [name: "identity_document_category_idx_system_subscription"]
    region_id [name: "identity_document_category_idx_region"]
    subregion_id [name: "identity_document_category_idx_subregion"]
    country_id [name: "identity_document_category_idx_country"]
    state_id [name: "identity_document_category_idx_state"]
    city_id [name: "identity_document_category_idx_city"]
  }
}

Table tenants.identity_document {
  id uuidv7
  identity_document_category_id uuidv7 [not null, ref: > tenants.identity_document_category.id]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  document varchar(250) [not null]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (identity_document_category_id, document) [unique, name: "identity_document_idx_unique"]
    system_subscription_id [name: "identity_document_idx_system_subscription"]
  }
}

Table tenants.identity_document_by_entity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id]
  identity_document_id uuidv7 [not null, ref: > tenants.identity_document.id]
  description text
  ordering uuidv7 [not null, default: 0]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (entity_id, identity_document_id) [unique, name: "identity_document_by_entity_idx_unique"]
    identity_document_id [name: "identity_document_by_entity_idx_identity_document"]
    system_subscription_id [name: "identity_document_by_entity_idx_system_subscription"]
  }
}

Table tenants.entity_name_type {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  type varchar(50) [unique, not null]
  apply_to_natural boolean [not null, default: true]
  apply_to_legal boolean [not null, default: true]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    system_subscription_id [name: "entity_name_type_idx_system_subscription"]
  }
}

Table tenants.entity_name {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  name varchar(250) [not null]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (system_subscription_id, name) [name: "entity_name_idx_unique"]
  }
}

Table tenants.entity_name_by_entity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id]
  entity_name_id uuidv7 [not null, ref: > tenants.entity_name.id]
  entity_name_type_id uuidv7 [not null, ref: > tenants.entity_name_type.id]
  ordering_by_type uuidv7 [not null, default: 0]
  description text
  ordering uuidv7 [not null, default: 0]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (entity_id, entity_name_id, entity_name_type_id) [unique, name: "entity_name_by_entity_idx_unique"]
    system_subscription_id [name: "entity_name_by_entity_idx_system_subscription"]
    entity_name_id [name: "entity_name_by_entity_idx_entity_name"]
    entity_name_type_id [name: "entity_name_by_entity_idx_entity_name_type"]
  }
}

Table tenants.entity_address {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [ref: > tenants.entity.id]
  region_id uuidv7 [ref: > osbs.regions.id]
  subregion_id uuidv7 [ref: > osbs.subregions.id]
  country_id uuidv7 [not null, ref: > osbs.countries.id]
  state_id uuidv7 [not null, ref: > osbs.states.id]
  city_id uuidv7 [ref: > osbs.cities.id]
  postal_code int
  custom_city varchar(250)
  description text
  is_preferred boolean [not null, default: false]
  ordering uuidv7 [not null, default: 0]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (entity_id, region_id, subregion_id, country_id, state_id, city_id, postal_code, custom_city) [unique, name: "entity_address_idx_unique"]
    system_subscription_id [name: "entity_address_idx_system_subscription"]
  }
}

Table tenants.phone_by_entity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  phone_id uuidv7 [not null, ref: > osbs.phone.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id]
  preferred boolean [not null, default: false]
  description text
  ordering uuidv7 [not null, default: 0]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (phone_id, entity_id) [unique, name: "phone_by_entity_idx_unique"]
    system_subscription_id [name: "phone_by_entity_idx_system_subscription"]
    entity_id [name: "phone_by_entity_idx_entity"]
  }
}

Table tenants.email_by_entity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  email_id uuidv7 [not null, ref: > osbs.email.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id]
  preferred boolean [not null, default: false]
  description text
  ordering uuidv7 [not null, default: 0]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (email_id, entity_id) [unique, name: "email_by_entity_idx_unique"]
    system_subscription_id [name: "email_by_entity_idx_system_subscription"]
    entity_id [name: "email_by_entity_idx_entity"]
  }
}

// ===============================================
// Departamento (jerárquico, por entidad jurídica)
// ===============================================
Table tenants.department {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [ref: > tenants.entity.id, note: "Must be null if parent_id fiel is not null. If parent_id field is null, this field must be not null."] // entidad jurídica dueña del departamento
  parent_id uuidv7 [ref: > tenants.department.id, note: "Must be null if entity_id fiel is not null. If entity_id field is null, this field must be not null."] // jerarquía (null = raíz)
  name varchar(250) [not null]
  description text
  code varchar(50) // opcional: código de departamento
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    (entity_id, parent_id, name) [unique, name: "department_idx_unique"]
    system_subscription_id [name: "department_idx_system_subscription"]
    parent_id [name: "department_idx_parent"]
  }
}

// ==============================================
// Familia de Cargos (Job Family)
// ==============================================
Table tenants.job_family {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id]
  name varchar(250) [not null]
  description text

  // Auditoría
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    (entity_id, name) [unique, name: "job_family_idx_unique"]
    system_subscription_id [name: "job_family_idx_system_subscription"]
  }
}

// ====================================================
// Cargo (Position) – jerárquico (reporta a otro cargo)
// ====================================================
Table tenants.position {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [ref: > tenants.entity.id, note: "Must be null if parent_id fiel is not null. If parent_id field is null, this field must be not null."] // entidad jurídica dueña del departamento
  parent_id uuidv7 [ref: > tenants.department.id, note: "Must be null if entity_id fiel is not null. If entity_id field is null, this field must be not null."] // jerarquía (null = raíz)
  job_family_id uuidv7 [ref: > tenants.job_family.id] // opcional, puede no tener familia
  department_id uuidv7 [ref: > tenants.department.id] // departamento al que pertenece
  name varchar(250) [not null]
  description text

  // Nivel jerárquico (opcional, para facilitar consultas)
  // level int

  // Auditoría
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    (entity_id, parent_id, job_family_id, department_id, name) [unique, name: "position_idx_unique"]
    system_subscription_id [name: "position_idx_system_subscription"]
    parent_id [name: "position_idx_parent"]
    job_family_id [name: "position_idx_job_family"]
    department_id [name: "position_idx_department"]
  }
}

// ==========================================================================
// Empleado (relaciona persona natural como empleado de una entidad jurídica)
// ==========================================================================
Table tenants.employee {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  person_entity_id uuidv7 [not null, ref: > tenants.entity.id] // la persona (is_natural = true)
  legal_entity_id uuidv7 [not null, ref: > tenants.entity.id] // empresa donde trabaja (is_natural = false)
  employee_code varchar(100) [not null] // código interno
  is_active boolean [not null, default: true]
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    (person_entity_id, legal_entity_id) [unique, name: "employee_idx_unique"]
    (legal_entity_id, employee_code) [unique, name: "employee_idx_unique_code_by_entity"]
    system_subscription_id [name: "employee_idx_system_subscription"]
  }
}

// =====================================================================================================
// Vigencia del empleado (establece las fechas de inicio y fin de periodos de un empleado en la empresa)
// =====================================================================================================
Table tenants.employee_validity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  employee_id uuidv7 [not null, ref: > tenants.employee.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    (employee_id, start_date) [name: "employee_validity_idx_unique"]
    system_subscription_id [name: "employee_validity_idx_system_subscription"]
  }
}

// ============================================================================
// Empleado por Cargo (relaciona empleado con un cargo de una entidad jurídica)
// ============================================================================
Table tenants.employee_per_position {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  employee_id uuidv7 [not null, ref: > tenants.employee.id]
  position_id uuidv7 [not null, ref: > tenants.position.id, note: "Must not exists 2 or more records with same position_id and is_active value in \"true\""]
  is_active boolean [not null, default: true]
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]

  Indexes {
    (employee_id, position_id) [unique, name: "employee_per_position_idx_unique"]
    system_subscription_id [name: "employee_per_position_idx_system_subscription"]
    position_id [name: "employee_per_position_idx_position"]
  }
}

// ============================================================================
// Vigencia de Empleado por Cargo (Historial de vigencia de empleado por cargo)
// ============================================================================
Table tenants.employee_per_position_validity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  employee_per_position_id uuidv7 [not null, ref: > tenants.employee_per_position.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    employee_per_position_id [name: "employee_per_position_validity_idx_employee_per_position"]
    system_subscription_id [name: "employee_per_position_validity_idx_system_subscription"]
  }
}

// ================================================================================================================
// Participación accionaria (participación accionaria de una entidad natural o jurídica sobre una entidad jurídica)
// ================================================================================================================
Table tenants.shareholding {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id] // entidad jurídica que tiene accionistas.
  shareholer_entity_id uuidv7 [not null, ref: > tenants.entity.id] // accionista (puede ser natural o jurídica)
  is_active boolean [not null, default: true]
  ownership_percentage decimal(5,2) // porcentaje de participación
  shares_quantity uuidv7 // cantidad de acciones (opcional)
  // share_class varchar(50) // clase de acción (ej: A, B, preferente)

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    (entity_id, shareholer_entity_id) [unique, name: "shareholding_idx_unique"]
    system_subscription_id [name: "shareholding_idx_system_subscription"]
    shareholer_entity_id [name: "shareholding_idx_shareholer_entity"]
  }
}

// ==========================================================================================================================
// Vigencia de la Participación accionaria (establece las fechas de inicio y fin de periodos de una participación accionaria)
// ==========================================================================================================================
Table tenants.shareholding_validity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  shareholding_id uuidv7 [not null, ref: > tenants.shareholding.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    shareholding_id [name: "shareholding_validity_idx_shareholding"]
    system_subscription_id [name: "shareholding_validity_idx_system_subscription"]
  }
}

// ==============================================
// Subsidiaria (relación matriz -> filial)
// ==============================================
Table tenants.subsidiary {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [not null, ref: > tenants.entity.id] // entidad filial (is_natural = false)
  parent_entity_id uuidv7 [not null, ref: > tenants.entity.id] // entidad matriz (is_natural = false)
  // Auditoría
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]

  Indexes {
    (entity_id, parent_entity_id) [name: "subsidiary_idx_unique"]
    system_subscription_id [name: "subsidiary_idx_system_subscription"]
    parent_entity_id [name: "subsidiary_idx_parent_entity"]
  }
}

// ==========================================================================================================================
// Vigencia de la Participación accionaria (establece las fechas de inicio y fin de periodos de una participación accionaria)
// ==========================================================================================================================
Table tenants.subsidiary_validity {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  subsidiary_id uuidv7 [not null, ref: > tenants.subsidiary.id]
  start_date timestampz [not null, note: "The value of this field must not be between the start_date and end_date of another record of same employee."]
  end_date timestampz [note: "Must not exists 2 records for 1 employee with this field with null value."]

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  deleted_at timestampz

  Indexes {
    subsidiary_id [name: "subsidiary_validity_idx_subsidiary"]
    system_subscription_id [name: "subsidiary_validity_idx_system_subscription"]
  }
}

// ==============================================
// Rama (relación matriz -> rama - sucursal)
// ==============================================
Table tenants.branch {
  id uuidv7 [pk, unique, not null]
  system_subscription_id uuidv7 [not null, ref: > osbs.system_subscription.id]
  entity_id uuidv7 [ref: > tenants.entity.id, note: "This field can be null when parent_id field is not null, else this field must be not null."]  // entidad jurídica dueña de la sucursal
  parent_id uuidv7 [ref: > tenants.branch.id, note: "This field can be null when entity_id field is not null, else this field must be not null."]  // rama padre de la sucursal
  position_id uuidv7 [ref: > tenants.position.id]  // cargo encargado de la sucursal
  subsidiary_id uuidv7 [ref: > tenants.subsidiary.id] // Si este campo apunta a una subsidiaria, entonces los campos "annulled_by_session_id" e "annulled_at" deben tener valor.
  is_headquarters boolean [default: false] // si es la casa matriz
  code varchar(50)                      // código interno
  name varchar(250) [null]          // "Sucursal Norte", "Oficina Madrid"
  /* address text
  city varchar(100)
  country varchar(100)
  phone varchar(50) */

  // Campos de registro de acción:
  created_at timestampz [not null, default: "now()"]
  updated_at timestampz [not null, default: "now()"]
  annulled_at timestampz
  deleted_at timestampz

  Indexes {
    (entity_id, parent_id, code) [name: "idx_branch_unique"]
    system_subscription_id [name: "branch_idx_system_subscription"]
    parent_id [name: "branch_idx_parent"]
    position_id [name: "branch_idx_position"]
    subsidiary_id [name: "branch_idx_subsidiary"]
  }
}

Table tenants.identity_document_by_entity_by_branch {
